---
import type { Props } from "@astrojs/starlight/props";

const entry = Astro.props.entry ?? Astro.locals.starlightRoute?.entry;
const data = entry?.data;
const hero = data?.hero;
const title = hero?.title || data?.title || "";
const tagline = hero?.tagline;
const actions = hero?.actions || [];

// Don't render hero if there's no hero data (e.g. 404 page)
const hasHero = !!hero;
---

<>
{hasHero && (
<section class="lotr-hero">
	{/* Ambient floating particles */}
	<div class="particles" aria-hidden="true">
		<span class="particle p1"></span>
		<span class="particle p2"></span>
		<span class="particle p3"></span>
		<span class="particle p4"></span>
		<span class="particle p5"></span>
		<span class="particle p6"></span>
		<span class="particle p7"></span>
	</div>

	{/* Ring glow backdrop */}
	<div class="ring-backdrop" aria-hidden="true"></div>

	<div class="hero-content">
		<h1 class="hero-title" set:html={title} />
		{tagline && <p class="hero-tagline" set:html={tagline} />}

		{
			actions.length > 0 && (
				<div class="hero-actions">
					{actions.map(
						({ text, link, variant }) => (
							<a href={link} class:list={["hero-btn", variant === "primary" && "hero-btn-primary"]}>
								{text}
							</a>
						)
					)}
				</div>
			)
		}

		<div class="hero-quote" aria-hidden="true">
			<em>"Not all those who wander are lost."</em>
		</div>
	</div>
</section>
)}
</>

<style>
	.lotr-hero {
		position: relative;
		overflow: hidden;
		padding: 6rem 2rem 5rem;
		text-align: center;
		min-height: 70vh;
		display: flex;
		align-items: center;
		justify-content: center;

		/* Dark atmospheric gradient */
		background: radial-gradient(
				ellipse 80% 60% at 50% 40%,
				hsla(38, 40%, 12%, 0.6) 0%,
				transparent 70%
			),
			radial-gradient(
				ellipse 50% 80% at 50% 100%,
				hsla(25, 30%, 6%, 0.8) 0%,
				transparent 60%
			),
			linear-gradient(
				180deg,
				var(--sl-color-black) 0%,
				hsl(28, 18%, 9%) 50%,
				var(--sl-color-black) 100%
			);
	}

	/* ——— Ring glow — warm golden ellipse ——— */
	.ring-backdrop {
		position: absolute;
		top: 35%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 400px;
		height: 400px;
		border-radius: 50%;
		background: radial-gradient(
			circle,
			hsla(38, 80%, 55%, 0.08) 0%,
			hsla(38, 60%, 40%, 0.03) 40%,
			transparent 70%
		);
		animation: ring-breathe 6s ease-in-out infinite;
		pointer-events: none;
	}

	@keyframes ring-breathe {
		0%,
		100% {
			opacity: 0.6;
			transform: translate(-50%, -50%) scale(1);
		}
		50% {
			opacity: 1;
			transform: translate(-50%, -50%) scale(1.1);
		}
	}

	/* ——— Floating particles — embers / elvish dust ——— */
	.particles {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}

	.particle {
		position: absolute;
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: hsla(38, 85%, 60%, 0.5);
		animation: float-up linear infinite;
	}

	.p1 { left: 15%; bottom: -5%; animation-duration: 12s; animation-delay: 0s; width: 2px; height: 2px; }
	.p2 { left: 35%; bottom: -5%; animation-duration: 15s; animation-delay: 2s; opacity: 0.7; }
	.p3 { left: 55%; bottom: -5%; animation-duration: 11s; animation-delay: 4s; width: 2px; height: 2px; }
	.p4 { left: 75%; bottom: -5%; animation-duration: 14s; animation-delay: 1s; opacity: 0.5; }
	.p5 { left: 25%; bottom: -5%; animation-duration: 16s; animation-delay: 3s; width: 2px; height: 2px; opacity: 0.6; }
	.p6 { left: 65%; bottom: -5%; animation-duration: 13s; animation-delay: 5s; opacity: 0.4; width: 2px; height: 2px; }
	.p7 { left: 45%; bottom: -5%; animation-duration: 10s; animation-delay: 6s; opacity: 0.8; }

	@keyframes float-up {
		0% {
			transform: translateY(0) translateX(0);
			opacity: 0;
		}
		10% {
			opacity: 1;
		}
		90% {
			opacity: 0.3;
		}
		100% {
			transform: translateY(-80vh) translateX(30px);
			opacity: 0;
		}
	}

	/* ——— Content ——— */
	.hero-content {
		position: relative;
		z-index: 1;
		max-width: 680px;
		margin: 0 auto;
		animation: hero-reveal 1s ease-out both;
	}

	@keyframes hero-reveal {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.hero-title {
		font-family: "Cinzel", "Palatino Linotype", serif !important;
		font-size: clamp(2.2rem, 5vw, 3.8rem);
		font-weight: 700;
		letter-spacing: 0.06em;
		line-height: 1.15;
		color: var(--sl-color-white);
		text-shadow: 0 0 30px hsla(38, 85%, 55%, 0.25),
			0 2px 10px hsla(25, 20%, 5%, 0.6);
		margin: 0 0 1.2rem;
	}

	.hero-tagline {
		font-family: "Crimson Pro", Georgia, serif;
		font-size: clamp(1.05rem, 2vw, 1.3rem);
		font-weight: 300;
		line-height: 1.7;
		color: var(--sl-color-gray-2);
		margin: 0 0 2.5rem;
		max-width: 560px;
		margin-inline: auto;
	}

	/* ——— Action buttons ——— */
	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 3rem;
	}

	.hero-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.75rem 1.5rem;
		border-radius: 999px;
		font-family: "Cinzel", serif;
		font-weight: 600;
		font-size: 0.95rem;
		letter-spacing: 0.04em;
		text-decoration: none;
		transition: box-shadow 0.3s ease, transform 0.3s ease,
			border-color 0.3s ease, text-shadow 0.3s ease;
		border: 1px solid hsla(38, 60%, 50%, 0.3);
		color: var(--sl-color-accent-high);
		background: transparent;
	}

	.hero-btn:hover {
		border-color: hsla(38, 70%, 55%, 0.6);
		text-shadow: 0 0 10px hsla(38, 85%, 55%, 0.3);
		transform: translateY(-1px);
	}

	.hero-btn-primary {
		background: linear-gradient(
			135deg,
			hsl(38, 70%, 42%) 0%,
			hsl(38, 85%, 55%) 100%
		);
		color: hsl(25, 18%, 7%);
		border: none;
		box-shadow: 0 0 20px hsla(38, 85%, 55%, 0.2),
			0 4px 12px hsla(25, 30%, 5%, 0.4);
	}

	.hero-btn-primary:hover {
		box-shadow: 0 0 30px hsla(38, 85%, 55%, 0.4),
			0 6px 20px hsla(25, 30%, 5%, 0.5);
		text-shadow: none;
	}

	/* ——— Tolkien quote — subtle easter egg ——— */
	.hero-quote {
		margin-top: 1rem;
		font-family: "Crimson Pro", Georgia, serif;
		font-size: 0.95rem;
		color: var(--sl-color-gray-3);
		opacity: 0;
		animation: quote-reveal 1s ease-out 1.2s both;
	}

	@keyframes quote-reveal {
		from {
			opacity: 0;
			transform: translateY(8px);
		}
		to {
			opacity: 0.5;
			transform: translateY(0);
		}
	}

	/* ——— Respect reduced motion ——— */
	@media (prefers-reduced-motion: reduce) {
		.ring-backdrop,
		.particle,
		.hero-content,
		.hero-quote {
			animation: none !important;
		}
		.hero-content,
		.hero-quote {
			opacity: 1;
		}
		.ring-backdrop {
			opacity: 0.6;
		}
	}
</style>
